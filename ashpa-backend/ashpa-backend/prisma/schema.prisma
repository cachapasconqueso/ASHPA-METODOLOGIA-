generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  Usuarios, roles y permisos (RBAC)
// ─────────────────────────────────────────────

model Usuario {
  id         String   @id @default(uuid())
  nombre     String
  email      String   @unique
  contrasena String
  creadoEn   DateTime @default(now()) @map("creado_en")

  roles             UsuarioRol[]
  aulasComoProfesor Aula[]
  inscripciones     AulaEstudiante[]
  progreso          ProgresoUsuario[]
  intentos          EvaluacionIntento[]
  insignias         InsigniaUsuario[]

  @@map("usuarios")
}

model Rol {
  id          String @id @default(uuid())
  nombre      String @unique
  descripcion String

  usuarios UsuarioRol[]
  permisos RolPermiso[]

  @@map("roles")
}

model Permiso {
  id          String @id @default(uuid())
  nombre      String @unique
  descripcion String

  roles RolPermiso[]

  @@map("permisos")
}

model UsuarioRol {
  usuarioId String @map("usuario_id")
  rolId     String @map("rol_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
  @@map("usuarios_roles")
}

model RolPermiso {
  rolId     String @map("rol_id")
  permisoId String @map("permiso_id")

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("roles_permisos")
}

// ─────────────────────────────────────────────
//  Aulas e inscripciones
// ─────────────────────────────────────────────

model Aula {
  id         String   @id @default(uuid())
  nombre     String
  codigo     String   @unique
  profesorId String   @map("profesor_id")
  creadoEn   DateTime @default(now()) @map("creado_en")

  profesor    Usuario          @relation(fields: [profesorId], references: [id], onDelete: Cascade)
  estudiantes AulaEstudiante[]
  modulos     Modulo[]

  @@map("aulas")
}

model AulaEstudiante {
  aulaId       String   @map("aula_id")
  estudianteId String   @map("estudiante_id")
  inscritoEn   DateTime @default(now()) @map("inscrito_en")

  aula       Aula    @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  estudiante Usuario @relation(fields: [estudianteId], references: [id], onDelete: Cascade)

  @@id([aulaId, estudianteId])
  @@map("aula_estudiantes")
}

// ─────────────────────────────────────────────
//  Módulos, ejercicios y evaluaciones
// ─────────────────────────────────────────────

model Modulo {
  id          String  @id @default(uuid())
  aulaId      String  @map("aula_id")
  nombre      String
  descripcion String
  nivel       Int     @default(1)
  orden       Int
  activo      Boolean @default(true)

  aula       Aula              @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  ejercicios Ejercicio[]
  evaluacion Evaluacion?
  progreso   ProgresoUsuario[]
  insignias  Insignia[]

  @@unique([aulaId, orden])
  @@map("modulos")
}

model Ejercicio {
  id        String   @id @default(uuid())
  moduloId  String   @map("modulo_id")
  tipo      String
  pregunta  String
  opciones  String[]
  respuesta String

  modulo Modulo @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@map("ejercicios")
}

model Evaluacion {
  id            String @id @default(uuid())
  moduloId      String @unique @map("modulo_id")
  puntajeMinimo Int    @default(70) @map("puntaje_minimo")

  modulo    Modulo               @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  preguntas EvaluacionPregunta[]
  intentos  EvaluacionIntento[]

  @@map("evaluaciones")
}

model EvaluacionPregunta {
  id           String   @id @default(uuid())
  evaluacionId String   @map("evaluacion_id")
  pregunta     String
  opciones     String[]
  respuesta    String

  evaluacion Evaluacion @relation(fields: [evaluacionId], references: [id], onDelete: Cascade)

  @@map("evaluacion_preguntas")
}

model EvaluacionIntento {
  id           String   @id @default(uuid())
  evaluacionId String   @map("evaluacion_id")
  usuarioId    String   @map("usuario_id")
  puntaje      Int
  aprobado     Boolean
  creadoEn     DateTime @default(now()) @map("creado_en")

  evaluacion Evaluacion @relation(fields: [evaluacionId], references: [id], onDelete: Cascade)
  usuario    Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("evaluacion_intentos")
}

// ─────────────────────────────────────────────
//  Progreso e insignias
// ─────────────────────────────────────────────

model ProgresoUsuario {
  id             String    @id @default(uuid())
  usuarioId      String    @map("usuario_id")
  moduloId       String    @map("modulo_id")
  completado     Boolean   @default(false)
  puntaje        Int?
  desbloqueadoEn DateTime? @map("desbloqueado_en")
  creadoEn       DateTime  @default(now()) @map("creado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  modulo  Modulo  @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, moduloId])
  @@map("progreso_usuario")
}

model Insignia {
  id          String  @id @default(uuid())
  moduloId    String? @map("modulo_id")
  nombre      String
  descripcion String
  icono       String

  modulo   Modulo?           @relation(fields: [moduloId], references: [id], onDelete: SetNull)
  usuarios InsigniaUsuario[]

  @@map("insignias")
}

model InsigniaUsuario {
  id         String   @id @default(uuid())
  usuarioId  String   @map("usuario_id")
  insigniaId String   @map("insignia_id")
  ganadaEn   DateTime @default(now()) @map("ganada_en")

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  insignia Insignia @relation(fields: [insigniaId], references: [id], onDelete: Cascade)

  @@map("insignias_usuario")
}
